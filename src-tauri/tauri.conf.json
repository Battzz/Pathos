{
	"$schema": "https://schema.tauri.app/config/2",
	"productName": "Pathos",
	"mainBinaryName": "Pathos",
	"version": "0.12.1",
	"identifier": "ai.pathos.desktop",
	"build": {
		"beforeDevCommand": "bun x vite",
		"devUrl": "http://localhost:1420",
		"beforeBuildCommand": "node scripts/prepare-sidecar.mjs && bun run build",
		"frontendDist": "../dist"
	},
	"plugins": {
		"deep-link": {
			"desktop": {
				"schemes": ["pathos", "pathos-dev"]
			}
		},
		"updater": {
			"pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDM5QkE5MEUwRjc5N0EzQ0QKUldUTm81ZjM0SkM2T2RweXFnOTYvanRkSENTRW9Zc25sMXRmeFlxazN1MFNZdjZPb2crVWNISzMK",
			"endpoints": [
				"https://github.com/dohooo/pathos/releases/latest/download/latest.json"
			]
		}
	},
	"app": {
		"macOSPrivateApi": true,
		"windows": [
			{
				"title": "Pathos",
				"width": 1300,
				"height": 810,
				"titleBarStyle": "Overlay",
				"trafficLightPosition": {
					"x": 12,
					"y": 20
				},
				"hiddenTitle": true,
				"center": true,
				"transparent": false
			}
		],
		"security": {
			"csp": null,
			"assetProtocol": {
				"enable": true,
				"scope": {
					"allow": ["**"]
				}
			}
		}
	},
	"bundle": {
		"active": true,
		"createUpdaterArtifacts": true,
		"targets": "all",
		"externalBin": [
			"../sidecar/dist/pathos-sidecar",
			"./target/bundled/pathos-cli"
		],
		"resources": {
			"../sidecar/dist/vendor/": "vendor"
		},
		"icon": [
			"icons/32x32.png",
			"icons/128x128.png",
			"icons/128x128@2x.png",
			"icons/icon.icns"
		],
		"macOS": {
			"entitlements": "Entitlements.plist"
		}
	}
}
